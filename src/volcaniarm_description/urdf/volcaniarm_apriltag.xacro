<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="volcaniarm_apriltag">

  <!-- AprilTag 36h11 ID 20 mounted on the end effector (sim only).
       Uses a DAE mesh with baked texture so it renders in both Gazebo and RViz.
       DAE has 64mm geometry, scaled up to 200mm for reliable detection in sim. -->

  <xacro:property name="tag_mesh"
    value="package://volcaniarm_description/models/Apriltag36_11_00020/apriltag_36h11_id20.dae" />
  <xacro:property name="tag_scale" value="${0.2 / 0.064}" />

  <!-- Tag visual link attached to right_arm_tip_link -->
  <link name="apriltag_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${tag_mesh}" scale="${tag_scale} ${tag_scale} ${tag_scale}" />
      </geometry>
    </visual>
  </link>

  <joint name="apriltag_joint" type="fixed">
    <!-- Tag mounted on EE tip, offset along X, face pointing in +X direction.
         The DAE quad face is on the Z plane, so rotate 90 deg around Y to face +X. -->
    <origin xyz="0.04 0 0" rpy="0 ${pi/2} 0" />
    <parent link="right_arm_tip_link" />
    <child link="apriltag_link" />
  </joint>

  <gazebo reference="apriltag_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

</robot>
