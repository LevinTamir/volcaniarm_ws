<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="volcaniarm_apriltag">

  <!-- AprilTag 36h11 ID 20 mounted on the end effector (sim only).
       The tag is a flat 64mm square facing the camera. -->

  <xacro:property name="tag_size" value="0.064" />
  <xacro:property name="tag_texture_path"
    value="$(find volcaniarm_description)/meshes/apriltag_36h11_id20.png" />

  <!-- Tag visual link attached to right_arm_tip_link -->
  <link name="apriltag_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
    <visual name="apriltag_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="${tag_size} ${tag_size} 0.001" />
      </geometry>
    </visual>
  </link>

  <joint name="apriltag_joint" type="fixed">
    <!-- Tag mounted on EE tip, face pointing along X axis, rotated 45 deg -->
    <origin xyz="0.04 0 0" rpy="0 1.5708 0.7854" />
    <parent link="right_arm_tip_link" />
    <child link="apriltag_link" />
  </joint>

  <gazebo reference="apriltag_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Apply the AprilTag texture in Gazebo -->
  <gazebo reference="apriltag_link">
    <visual name="apriltag_visual">
      <material>
        <diffuse>1 1 1 1</diffuse>
        <specular>0 0 0 0</specular>
        <pbr>
          <metal>
            <albedo_map>${tag_texture_path}</albedo_map>
            <metalness>0.0</metalness>
            <roughness>1.0</roughness>
          </metal>
        </pbr>
      </material>
    </visual>
  </gazebo>

</robot>
