        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/volcaniarm_right_arm_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="volcaniarm_right_arm_joint" type="revolute">
    <origin xyz="0.004 -0.02 0.41621" rpy="1.7053 0 0" />
    <parent link="volcaniarm_right_elbow_link" />
    <child link="volcaniarm_right_arm_link" />
    <axis xyz="1 0 0" />
    <limit lower="-3.14" upper="3.14" effort="10" velocity="10" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>

  <!-- ======================== CAMERA MOUNT ======================== -->

  <link name="camera_mount_linear_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_mount_linear_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_mount_linear_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="camera_mount_linear_joint" type="fixed">
    <origin xyz="0.405353761834025 0 0.039999999999992" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_mount_linear_link" />
  </joint>

  <link name="camera_mount_rev_link">
    <inertial>
      <origin xyz="-0.00010268 -1.5812E-06 0.01215" rpy="0 0 0" />
      <mass value="0.006837" />
      <inertia ixx="2.4745E-06" ixy="8.8137E-13" ixz="-4.848E-10"
               iyy="2.6062E-07" iyz="-1.1636E-11" izz="2.5357E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_mount_rev_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_mount_rev_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="camera_mount_rev_joint" type="fixed">
    <origin xyz="0.192000000000008 0 -0.0290000000000052"
            rpy="3.14159265358979 0.9 3.14159265358979" />
    <parent link="camera_mount_linear_link" />
    <child link="camera_mount_rev_link" />
  </joint>

  <!-- ======================== CAMERA ======================== -->

  <link name="camera_link">
    <inertial>
      <origin xyz="-6.0219E-07 0.00024591 0.011952" rpy="0 0 0" />
      <mass value="0.044753" />
      <inertia ixx="2.7362E-05" ixy="3.9858E-09" ixz="7.9052E-10"
               iyy="3.9447E-06" iyz="2.4433E-07" izz="2.7278E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/camera_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.0160004150359285 0 0" rpy="3.14159 0 0" />
    <parent link="camera_mount_rev_link" />
    <child link="camera_link" />
  </joint>

  <!-- Camera optical frame -->
  <link name="camera_link_optical" />
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    <parent link="camera_link" />
    <child link="camera_link_optical" />
  </joint>

  <!-- ======================== 5-BAR LINKAGE CLOSURE ======================== -->

  <!-- Massless tip frame fixed to the right arm at the physical closure point -->
  <link name="right_arm_tip_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.008" />
      </geometry>
      <material name="tip_green">
        <color rgba="0.0 1.0 0.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.008" />
      </geometry>
    </collision>
  </link>
  <joint name="right_arm_tip_joint" type="fixed">
    <origin xyz="0 0 0.6225" rpy="0 0 0" />
    <parent link="volcaniarm_right_arm_link" />
    <child link="right_arm_tip_link" />
  </joint>
  <!-- Prevent Gazebo from merging this fixed joint so DetachableJoint can find the link -->
  <gazebo reference="right_arm_tip_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Closure dummy link: URDF-tree leaf on the left arm, DetachableJoint target -->
  <link name="closure_dummy_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.008" />
      </geometry>
      <material name="closure_purple">
        <color rgba="0.6 0.0 0.8 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.008" />
      </geometry>
    </collision>
  </link>
  <joint name="closure_joint" type="revolute">
    <origin xyz="0 0 0.6225" rpy="1.8398 0 0" />
    <parent link="volcaniarm_left_arm_link" />
    <child link="closure_dummy_link" />
    <axis xyz="1 0 0" />
    <limit lower="-3.14" upper="3.14" effort="0" velocity="10" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

</robot>
