<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="volcaniarm">

  <xacro:arg name="is_ignition" default="true" />

   <!-- ros2_control hardware interfaces -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_ros2_control.xacro" />

    <!-- Include Gazebo plugins -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_gazebo.xacro" />

  <!-- World fixed link -->
  <link name="world" />
  <joint name="world_to_base" type="fixed">
    <origin xyz="0 0 1" rpy="0 0 0" />
    <parent link="world" />
    <child link="delta_arm_base_link" />
  </joint>

  <!-- base -->

  <link
    name="delta_arm_base_link">
    <inertial>
      <origin
        xyz="0.044852 5.6163E-11 -0.047504"
        rpy="0 0 0" />
      <mass
        value="3.6689" />
      <inertia
        ixx="0.037076"
        ixy="-5.2217E-06"
        ixz="-0.00045503"
        iyy="0.0099763"
        iyz="-2.5372E-12"
        izz="0.042777" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/delta_arm_base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/delta_arm_base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- right elbow -->

  <link
    name="right_elbow_link">
    <inertial>
      <origin
        xyz="0.034442 0.0032708 -0.20791"
        rpy="0 0 0" />
      <mass
        value="0.25563" />
      <inertia
        ixx="0.0015999"
        ixy="-2.5707E-06"
        ixz="4.8958E-07"
        iyy="0.0016014"
        iyz="2.7775E-06"
        izz="8.8967E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/right_elbow_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/right_elbow_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint
    name="right_elbow_joint"
    type="revolute">
    <origin
      xyz="0.1825 -0.215 -0.0582"
      rpy="0 0 0" />
    <parent
      link="delta_arm_base_link" />
    <child
      link="right_elbow_link" />
    <axis
      xyz="1 0 0" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="10"
      velocity="10" />
  </joint>

  <!-- left elbow -->
   
  <link
    name="left_elbow_link">
    <inertial>
      <origin
        xyz="0.034442 -0.00032898 -0.20791"
        rpy="0 0 0" />
      <mass
        value="0.25563" />
      <inertia
        ixx="0.0015999"
        ixy="-2.5707E-06"
        ixz="4.8958E-07"
        iyy="0.0016014"
        iyz="-4.1043E-06"
        izz="8.8968E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/left_elbow_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/left_elbow_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint
    name="left_elbow_joint"
    type="revolute">
    <origin
      xyz="0.1825 0.215 -0.0582"
      rpy="0 0 0" />
    <parent
      link="delta_arm_base_link" />
    <child
      link="left_elbow_link" />
    <axis
      xyz="1 0 0" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="10"
      velocity="10" />
  </joint>

  <!-- Camera link -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.5 0 0.1" rpy="0 1.7 0" />
    <parent link="delta_arm_base_link" />
    <child link="camera_link" />
  </joint>

  <!-- Camera optical frame -->
  <link name="camera_link_optical" />

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    <parent link="camera_link" />
    <child link="camera_link_optical" />
  </joint>


  <!-- STRAT BREAK -->

