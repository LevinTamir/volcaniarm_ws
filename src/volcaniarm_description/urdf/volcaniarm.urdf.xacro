<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="volcaniarm">

  <xacro:arg name="use_sim" default="true" />

   <!-- ros2_control hardware interfaces -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_ros2_control.xacro" />

    <!-- Include Gazebo plugins -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_gazebo.xacro" />

  <!-- Include RealSense camera frames for real hardware -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_realsense.xacro" />

  <!-- World fixed link -->
  <link name="world" />
  <joint name="world_to_base" type="fixed">
    <origin xyz="0 0 0.98" rpy="0 0 3.14159" />
    <parent link="world" />
    <child link="base_link" />
  </joint>

  <!-- base (table top) -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0033183 1.7612E-06 -0.24794" rpy="0 0 0" />
      <mass value="5.4796" />
      <inertia ixx="0.36605" ixy="-2.0049E-09" ixz="1.5542E-08"
               iyy="0.19294" iyz="-3.1213E-09" izz="0.31414" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://volcaniarm_description/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- ======================== TABLE LEGS ======================== -->

