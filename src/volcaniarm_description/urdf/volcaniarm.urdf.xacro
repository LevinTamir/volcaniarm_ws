<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="volcaniarm">

  <xacro:arg name="is_ignition" default="true" />

   <!-- ros2_control hardware interfaces -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_ros2_control.xacro" />

    <!-- Include Gazebo plugins -->
  <xacro:include filename="$(find volcaniarm_description)/urdf/volcaniarm_gazebo.xacro" />

  <!-- World fixed link -->
  <link name="world" />
  <joint name="world_to_base" type="fixed">
    <origin xyz="0 0 1.0" rpy="3.14159 0 0" />
    <parent link="world" />
    <child link="delta_arm_base_link" />
  </joint>

  <!-- base -->

  <link
    name="delta_arm_base_link">
    <inertial>
      <origin
        xyz="0.0448523615659837 -5.61618529459906E-11 0.0475041838279733"
        rpy="0 0 0" />
      <mass
        value="3.66893125370708" />
      <inertia
        ixx="0.0370764826444317"
        ixy="5.22170430710044E-06"
        ixz="0.000455029302088239"
        iyy="0.00997633418242008"
        iyz="-2.53723287794529E-12"
        izz="0.042776927188676" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/delta_arm_base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/delta_arm_base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- right elbow -->

  <link
    name="right_elbow_link">
    <inertial>
      <origin
        xyz="0.0344418579623738 0.207911851059774 0.00327083348162716"
        rpy="0 0 0" />
      <mass
        value="0.255626035233683" />
      <inertia
        ixx="0.00159990350392906"
        ixy="-4.89579235407502E-07"
        ixz="-2.57067549462293E-06"
        iyy="8.89672102610009E-05"
        iyz="-2.77751340707856E-06"
        izz="0.00160137777854202" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/right_elbow_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/right_elbow_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint
    name="right_elbow_joint"
    type="revolute">
    <origin
      xyz="0.1825 0.215 0.0582"
      rpy="0 0 0" />
    <parent
      link="delta_arm_base_link" />
    <child
      link="right_elbow_link" />
    <axis
      xyz="1 0 0" />
    <limit
      lower="-3.14"
      upper="3.14"
      effort="10"
      velocity="10" />
  </joint>

  <!-- left elbow -->
   
  <link
    name="left_elbow_link">
    <inertial>
      <origin
        xyz="0.0344418579623738 0.207911854085233 -0.000328981745472023"
        rpy="0 0 0" />
      <mass
        value="0.255626035233677" />
      <inertia
        ixx="0.00159990350392901"
        ixy="-4.89578784056069E-07"
        ixz="-2.57068360841827E-06"
        iyy="8.89679482853774E-05"
        iyz="4.10433625636923E-06"
        izz="0.00160137704051758" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/left_elbow_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://volcaniarm_description/meshes/left_elbow_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint
    name="left_elbow_joint"
    type="revolute">
    <origin
      xyz="0.1825 -0.215 0.0582"
      rpy="0 0 0" />
    <parent
      link="delta_arm_base_link" />
    <child
      link="left_elbow_link" />
    <axis
      xyz="1 0 0" />
    <limit
      lower="-3.14"
      upper="3.14"
      effort="10"
      velocity="10" />
  </joint>

  <!-- Camera link -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.5 0 0.1" rpy="0 -1.8 0" />
    <parent link="delta_arm_base_link" />
    <child link="camera_link" />
  </joint>

  <!-- Camera optical frame -->
  <link name="camera_link_optical" />

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    <parent link="camera_link" />
    <child link="camera_link_optical" />
  </joint>


