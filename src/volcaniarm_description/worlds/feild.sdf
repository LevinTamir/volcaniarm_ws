<sdf version="1.6">
  <world name="feild">
    <physics name="1ms" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <dart>
        <solver>
          <solver_type>pgs</solver_type>
        </solver>
        <collision_detector>ode</collision_detector>
      </dart>
    </physics>
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin
      filename="gz-sim-contact-system"
      name="gz::sim::systems::Contact">
    </plugin>

    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>
    <plugin
      filename="gz-sim-navsat-system"
      name="gz::sim::systems::NavSat">
    </plugin>
    
    <!-- Sky -->
    <scene>
    <grid>false</grid>
    <ambient>0.4 0.4 0.4 1</ambient>
    <background>0.7 0.8 1.0 1</background>
      <sky>
        <clouds>
          <speed>12</speed>
        </clouds>
      </sky>
    </scene>
    
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Gravity -->
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <!-- Field floor scaled to cover entire ground -->
    <include>
      <uri>model://field_floor</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <include>
      <uri>model://plant</uri>
      <name>plant_1</name>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <include>
      <uri>model://plant</uri>
      <name>plant_2</name>
      <pose>2 0 0 0 0 0</pose>
    </include> 

    <include>
      <uri>model://plant</uri>
      <name>plant_3</name>
      <pose>3 0 0 0 0 0</pose>
    </include> 

    <include>
      <uri>model://plant</uri>
      <name>plant_4</name>
      <pose>4 0 0 0 0 0</pose>
    </include>

    <include>
      <uri>model://plant</uri>
      <name>plant_5</name>
      <pose>1 0 0 0 0 0</pose>
    </include>

    <!-- Trees around the perimeter -->
    <include>
      <uri>model://oak_tree</uri>
      <name>oak_tree_1</name>
      <pose>-10 -10 0 0 0 0</pose>
    </include>

    <include>
      <uri>model://oak_tree</uri>
      <name>oak_tree_2</name>
      <pose>15 -8 0 0 0 0.5</pose>
    </include>

    <include>
      <uri>model://pine_tree</uri>
      <name>pine_tree_1</name>
      <pose>-12 10 0 0 0 1.2</pose>
    </include>

    <include>
      <uri>model://pine_tree</uri>
      <name>pine_tree_2</name>
      <pose>18 12 0 0 0 2.8</pose>
    </include>

    <include>
      <uri>model://oak_tree</uri>
      <name>oak_tree_3</name>
      <pose>20 -15 0 0 0 1.8</pose>
    </include>

    <include>
      <uri>model://pine_tree</uri>
      <name>pine_tree_3</name>
      <pose>-15 -12 0 0 0 0.3</pose>
    </include>

    <!-- Additional vegetation for realism -->
    <include>
      <uri>model://big_plant</uri>
      <name>big_plant_1</name>
      <pose>-8 5 0 0 0 0.8</pose>
    </include>

    <include>
      <uri>model://big_plant</uri>
      <name>big_plant_2</name>
      <pose>12 -5 0 0 0 2.1</pose>
    </include>

    <include>
      <uri>model://big_plant</uri>
      <name>big_plant_3</name>
      <pose>-10 -5 0 0 0 1.5</pose>
    </include>

    <include>
      <uri>model://big_plant</uri>
      <name>big_plant_4</name>
      <pose>15 8 0 0 0 0.3</pose>
    </include>

    <include>
      <uri>model://oak_tree</uri>
      <name>oak_tree_4</name>
      <pose>-5 -15 0 0 0 2.3</pose>
    </include>

    <include>
      <uri>model://pine_tree</uri>
      <name>pine_tree_4</name>
      <pose>10 15 0 0 0 1.7</pose>
    </include>

  </world>
</sdf>